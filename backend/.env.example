# ============================================================================
# FinanceFlow Backend Environment Variables Example
# Copy this file to '.env' and fill in your actual credentials.
# ============================================================================

# Port for Express server
PORT=5000

# Environment mode (development / production)
NODE_ENV=development

# Supabase Credentials (Required for auth validation and data syncing)
SUPABASE_URL=https://your-supabase-project-id.supabase.co
# Note: Use the service role key only in the backend as it bypasses RLS policies!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenRouter API Key (Required for AI model queries)
# (Get yours from https://openrouter.ai/)
OPENROUTER_API_KEY=your-openrouter-api-key
